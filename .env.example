# ============================================
# Enclavr Infrastructure Environment Variables
# ============================================
# Copy this file to .env and customize for your deployment
# Never commit .env to version control - it contains secrets

# --------------------------------------------
# Database Configuration (PostgreSQL Container)
# These are used by the PostgreSQL Docker container to initialize the database
# NOTE: These set the INITIAL credentials when the container first starts
# The Go server uses DB_* variables below to connect
# --------------------------------------------
# WARNING: Change these before deploying to production!
POSTGRES_USER=enclavr
POSTGRES_PASSWORD=CHANGE_ME_generate_with_openssl_rand_base64_32
POSTGRES_DB=enclavr

# --------------------------------------------
# Go Backend Server Configuration
# --------------------------------------------
SERVER_PORT=8080
SERVER_READ_TIMEOUT=30s
SERVER_WRITE_TIMEOUT=30s

# --------------------------------------------
# Admin User Configuration
# --------------------------------------------
# The first user to register will become admin (when FIRST_USER_IS_ADMIN=true)
# Alternatively, set ADMIN_PASSWORD to create a default admin user on startup
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
ADMIN_EMAIL=admin@enclavr.local
FIRST_USER_IS_ADMIN=true

# --------------------------------------------
# Database Connection (Server -> PostgreSQL)
# These are used by the Go server to connect to the PostgreSQL container
# CRITICAL: DB_USER and DB_PASSWORD must match POSTGRES_USER and POSTGRES_PASSWORD above
# DB_HOST should be 'postgres' when running in Docker, 'localhost' for local development
# --------------------------------------------
DB_HOST=postgres
DB_PORT=5432
DB_USER=enclavr
DB_PASSWORD=CHANGE_ME_must_match_POSTGRES_PASSWORD
DB_NAME=enclavr
DB_SSLMODE=disable  # Set to 'require' in production with valid certificates

# --------------------------------------------
# Authentication (JWT)
# --------------------------------------------
# IMPORTANT: Generate a strong random secret before deploying!
# Generate with: openssl rand -base64 64
# DO NOT use the default value in production - it allows token forgery!
# The server will fail to start if this is not set.
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_64
JWT_EXPIRATION=24h       # Access token lifetime
REFRESH_EXPIRATION=168h  # Refresh token lifetime (7 days)

# --------------------------------------------
# 2FA Encryption
# --------------------------------------------
# Encrypts 2FA secrets in the database (REQUIRED for production)
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=CHANGE_ME_generate_with_openssl_rand_base64_32

# --------------------------------------------
# OIDC Authentication (Optional)
# --------------------------------------------
# Enable OIDC provider (Google, GitHub, etc.)
OIDC_ENABLED=false
OIDC_ISSUER_URL=https://your-oidc-provider.com
OIDC_CLIENT_ID=your-client-id
OIDC_CLIENT_SECRET=your-client-secret

# --------------------------------------------
# WebRTC Voice Chat (STUN/TURN)
# --------------------------------------------
# STUN server for NAT traversal (Google's public STUN)
STUN_SERVER=stun:stun.l.google.com:19302

# TURN server for restrictive networks (required for reliable voice)
# Leave empty to disable TURN (not recommended for production)
TURN_SERVER=
TURN_USER=enclavr
TURN_PASS=CHANGE_ME_generate_with_openssl_rand_base64_16
REALM=enclavr

# TURN TLS Certificates (required for TLS/DTLS)
# Generate self-signed certs: ./generate-turn-certs.sh
# For production, use real certificates (e.g., from Let's Encrypt)
# Place cert.pem and key.pem in ./certs/turn/

# --------------------------------------------
# Redis Pub/Sub (for horizontal scaling)
# --------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_generate_with_openssl_rand_base64_16
REDIS_DB=0

# --------------------------------------------
# CORS Configuration (Optional)
# --------------------------------------------
# Comma-separated list of allowed origins for API access
# Example: ALLOWED_ORIGINS=https://enclavr.example.com,https://app.enclavr.com
ALLOWED_ORIGINS=

# --------------------------------------------
# File Uploads
# --------------------------------------------
MAX_UPLOAD_SIZE_MB=10    # Maximum upload size in megabytes
UPLOAD_DIR=./uploads     # Directory for storing uploaded files (mounted as volume in production)

# --------------------------------------------
# Push Notifications (Web Push - Optional)
# --------------------------------------------
# Generate VAPID keys with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@enclavr.local

# --------------------------------------------
# Sentry Error Tracking (Optional)
# --------------------------------------------
# Get DSN from https://enclavr.sentry.io/settings/frontend/keys/
# Frontend (public - can use NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production

# Server (private - no prefix needed)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# --------------------------------------------
# Frontend Build Args (passed during Docker build)
# --------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_STUN_SERVER=stun:stun.l.google.com:19302
NEXT_PUBLIC_TURN_SERVER=
NEXT_PUBLIC_TURN_USER=

# --------------------------------------------
# Monitoring & Metrics (Prometheus + Grafana)
# --------------------------------------------
# Grafana admin credentials
# WARNING: Generate a strong password before deploying!
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_ME_generate_with_openssl_rand_base64_16
GRAFANA_ROOT_URL=
GRAFANA_SERVE_FROM_SUB_PATH=false

# --------------------------------------------
# Automated PostgreSQL Backups
# --------------------------------------------
# Cron schedule for backups (default: daily at 2 AM)
BACKUP_CRON=0 2 * * *
# Number of days to retain backups
BACKUP_RETENTION_DAYS=7

# --------------------------------------------
# Log Aggregation (Loki + Alloy)
# --------------------------------------------
# Loki retention period (default: 30 days)
# Configured in loki-config.yaml - no env vars needed
# Alloy collects logs from all containers labeled logging=alloy

# --------------------------------------------
# TLS Termination (Caddy Reverse Proxy)
# --------------------------------------------
# Enable with: docker compose --profile tls up -d
# Caddy provides automatic HTTPS with Let's Encrypt
DOMAIN=enclavr.example.com
ACME_EMAIL=admin@example.com

# Optional: Monitoring dashboard domain (requires --profile tls --profile monitoring)
MONITORING_DOMAIN=
GRAFANA_BASIC_AUTH_USER=admin
GRAFANA_BASIC_AUTH_HASH=  # Generate with: caddy hash-password --plaintext 'password'

# --------------------------------------------
# Automated Container Updates (Watchtower)
# --------------------------------------------
# Enable with: docker compose --profile maintenance up -d
# Only updates containers with com.centurylinklabs.watchtower.enable=true label
WATCHTOWER_POLL_INTERVAL=86400  # Check for updates every 24 hours (in seconds)
WATCHTOWER_LOG_LEVEL=info       # Log level: panic, fatal, error, warn, info, debug, trace

# --------------------------------------------
# Docker Compose Profiles
# --------------------------------------------
# Use profiles to control which services start:
#   Core (default): postgres, redis, server, frontend
#   --profile monitoring: + prometheus, grafana, loki, exporters, alloy, alertmanager
#   --profile voice: + coturn TURN server
#   --profile backup: + postgres-backup
#   --profile tls: + caddy reverse proxy (automatic HTTPS)
#   --profile maintenance: + watchtower (automated updates)
#   --profile full: all services
#
# Examples:
#   docker compose up -d                          # Core services only
#   docker compose --profile monitoring up -d     # Core + monitoring
#   docker compose --profile tls up -d            # Core + TLS termination
#   docker compose --profile maintenance up -d    # Core + auto-updates
#   docker compose --profile full up -d           # All services
#
# Development:
#   make dev                                      # Development mode (hot reload)
#   make prod                                     # Production mode (all services)
#   make help                                     # Show all available commands

# --------------------------------------------
# Production Recommendations
# --------------------------------------------
# 1. Change all default passwords (POSTGRES_PASSWORD, DB_PASSWORD, TURN_PASS)
# 2. Set a strong JWT_SECRET (minimum 256-bit entropy)
# 3. Enable SSL for database connections (DB_SSLMODE=require)
# 4. Configure TURN server with proper credentials
# 5. Set ALLOWED_ORIGINS to your frontend URL(s)
# 6. Use environment-specific .env files (.env.production, .env.staging)
# 7. Rotate secrets regularly and use a secrets manager in production
# 8. Monitor logs via Grafana (Loki datasource) at port 3030
# 9. Configure BACKUP_RETENTION_DAYS based on your backup policy

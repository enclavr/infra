# Server Configuration

# Database
POSTGRES_USER=enclavr
POSTGRES_PASSWORD=enclavr
POSTGRES_DB=enclavr

# Server
SERVER_PORT=8080
SERVER_READ_TIMEOUT=30s
SERVER_WRITE_TIMEOUT=30s

# Database
DB_HOST=postgres
DB_PORT=5432
DB_USER=enclavr
DB_PASSWORD=enclavr
DB_NAME=enclavr
DB_SSLMODE=disable

# Authentication
JWT_SECRET=change-this-in-production
JWT_EXPIRATION=24h
REFRESH_EXPIRATION=168h

# OIDC (Optional)
OIDC_ENABLED=false
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# Voice (WebRTC)
STUN_SERVER=stun:stun.l.google.com:19302
TURN_SERVER=
TURN_USER=
TURN_PASS=

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# CORS (Optional - comma-separated origins)
ALLOWED_ORIGINS=

# File Uploads
MAX_UPLOAD_SIZE_MB=10
UPLOAD_DIR=./uploads

# Push Notifications (VAPID)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@enclavr.local

{
	# Email for Let's Encrypt notifications
	email {$ACME_EMAIL}

	# Use staging CA for testing (remove for production)
	# acme_ca https://acme-staging-v02.api.letsencrypt.org/directory
}

# Frontend - automatic HTTPS
{$DOMAIN} {
	reverse_proxy frontend:80

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(self), geolocation=()"
		-Server
	}

	# Security: Block access to hidden files
	@blocked path /.git* /.env* /.docker* /docker-compose*
	handle @blocked {
		abort
	}

	encode gzip
	log {
		output stdout
		format console
	}
}

# API - automatic HTTPS with WebSocket support for voice chat
api.{$DOMAIN} {
	reverse_proxy server:8080 {
		header_up Host {host}
		header_up X-Real-IP {remote}
		header_up X-Forwarded-For {remote}
		header_up X-Forwarded-Proto {scheme}
	}

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		-Server
	}

	# NOTE: API rate limiting requires a custom Caddy build with caddy-ratelimit module
	# Build with: xcaddy build --with github.com/mholt/caddy-ratelimit
	# Then update the docker-compose.yml image to use your custom build

	encode gzip
	log {
		output stdout
		format console
	}
}

